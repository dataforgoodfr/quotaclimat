# Dockerfile for press ingestion pipelines (Le Monde FTP, OuestFrance API)
# Usage:
#   docker build -f Dockerfile_lemonde_web . -t press_ingestion
#   docker run press_ingestion                            # defaults to lemonde
#   docker run press_ingestion ouest_france               # OuestFrance pipeline
#   docker run -e DEFAULT_PIPELINE=ouest_france press_ingestion  # via env var
#
# To bake in a different default pipeline at build time:
#   docker build -f Dockerfile_lemonde_web --build-arg DEFAULT_PIPELINE=ouest_france . -t ouest_france

FROM python:3.12.10 AS builder

ENV VIRTUAL_ENV=/app/.venv
ENV POETRY_NO_INTERACTION=1 \
    POETRY_VIRTUALENVS_IN_PROJECT=1 \
    POETRY_VIRTUALENVS_CREATE=1 \
    POETRY_CACHE_DIR=/tmp/poetry_cache

WORKDIR /app

COPY pyproject.toml poetry.lock ./
RUN pip install poetry==2.1.3
RUN poetry install --no-root --without dev

FROM python:3.12.10-slim AS runtime

WORKDIR /app

ENV VIRTUAL_ENV=/app/.venv
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH=/app

COPY --from=builder ${VIRTUAL_ENV} ${VIRTUAL_ENV}

# Copy application code
COPY quotaclimat ./quotaclimat
COPY postgres ./postgres
COPY pyproject.toml ./pyproject.toml
COPY alembic_factiva/ ./alembic_factiva
COPY alembic_factiva.ini ./alembic_factiva.ini

# Create tmp directories for temporary files
RUN mkdir -p /tmp/s3_factiva_to_postgre \
    /tmp/s3_lemonde_to_postgre \
    /tmp/lemonde_ftp \
    /tmp/ouest_france_articles

# Healthcheck port
EXPOSE 5000

# Copy entrypoint script
COPY docker-entrypoint-press-ingestion.sh ./docker-entrypoint-press-ingestion.sh
RUN chmod +x ./docker-entrypoint-press-ingestion.sh

# Default pipeline (override at build time with --build-arg, or at run time with -e or CLI arg)
ARG DEFAULT_PIPELINE=lemonde
ENV DEFAULT_PIPELINE=${DEFAULT_PIPELINE}

ENTRYPOINT ["./docker-entrypoint-press-ingestion.sh"]
