# Infrastructure secrets.
# Auto-populated by: make sync-secrets (fetches from Vaultwarden)
# Manual setup: copy to .env.secrets and fill in all values.
#
# Vaultwarden collections:
#   "Quotaclimat - Désinformation/" — Terraform secrets (advertising, barometre, rrs)
#   "Quotaclimat - Orchestrator/"   — Kestra, GlitchTip, and flow secrets

# --- Infrastructure ---
BASE_DOMAIN=
ACME_EMAIL=admin@quotaclimat.fr

# --- Traefik ---
# Generate with: htpasswd -nB admin | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=

# --- Kestra (service config) ---
KESTRA_BASIC_AUTH=
KESTRA_DB_USER=
KESTRA_DB_PASSWORD=
KESTRA_DB_NAME=

# --- GlitchTip (service config) ---
GLITCHTIP_DB_USER=
GLITCHTIP_DB_PASSWORD=
GLITCHTIP_DB_NAME=
GLITCHTIP_SECRET_KEY=

# --- Managed Postgres (connection to Scaleway RDB) ---
POSTGRES_HOST=
POSTGRES_PORT=5432

# --- Kestra flow secrets (provisioned into Kestra's secret store) ---
KESTRA_FLOW_POSTGRES_USER=
KESTRA_FLOW_POSTGRES_PASSWORD=
LABELSTUDIO_INGESTION_POSTGRES_USER=
LABELSTUDIO_INGESTION_POSTGRES_PASSWORD=
MEDIATREE_USER=
MEDIATREE_PASSWORD=
SCW_BUCKET=
SCW_BUCKET_SECRET=
FACTIVA_USERKEY=
FACTIVA_SUBSCRIPTION_ID=
FACTIVA_POSTGRES_USER=
FACTIVA_POSTGRES_PASSWORD=
LEMONDE_FTP_HOST=
LEMONDE_FTP_USER=
LEMONDE_FTP_PASS=
RRS_PG_USER=
RRS_PG_PASSWORD=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# --- Kestra flow KV store (non-secret config) ---
CONTAINER_REGISTRY=
KESTRA_FLOW_POSTGRES_DB=barometre
KESTRA_FLOW_POSTGRES_HOST=
KESTRA_FLOW_POSTGRES_PORT=5432
BUCKET_NAME=
FACTIVA_POSTGRES_DB=print_media_db
FACTIVA_POSTGRES_HOST=
FACTIVA_POSTGRES_PORT=5432
RRS_REGISTRY=
RRS_PG_HOST=
RRS_PG_PORT=5432
RRS_PG_DATABASE=
