# Sensitive variables for the advertising dev environment.
# Copy this file to .env.secrets and populate the values.
# Secrets are available in the DataForGood Vaultwarden password manager
# under the collection: Quotaclimat - Désinformation/

export TF_VAR_labelstudio_admin_password=
export TF_VAR_labelstudio_user_token=
export TF_VAR_postgres_password_labelstudio=
# TF_VAR_barometre_pg_instance_name=rdb-poc  # optional — defaults to rdb-poc
