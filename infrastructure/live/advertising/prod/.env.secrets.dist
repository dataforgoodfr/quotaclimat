# Sensitive variables for the advertising dev environment.
# Copy this file to .env.secrets and populate the values.
# Secrets are available in the DataForGood Vaultwarden password manager
# under the collection: Quotaclimat - Désinformation/

# Label Studio credentials
export TF_VAR_labelstudio_admin_password=
export TF_VAR_labelstudio_user_token=

# PostgreSQL password for the Label Studio DB user
export TF_VAR_postgres_password_labelstudio=

# PostgreSQL admin credentials and connection details for the barometre RDB instance
# (used to configure fine-grained grants for the dgccrf user)
export TF_VAR_postgres_host=
export TF_VAR_postgres_admin_user=
export TF_VAR_postgres_admin_password=
export TF_VAR_postgres_port=

# Password for the dgccrf user that will be created
export TF_VAR_dgccrf_user_password=

export TF_VAR_barometre_pg_instance_name=rdb-barometre-dev  # optional — defaults to rdb-poc
