# Variables for the barometre dev environment.
# Copy this file to .env.secrets and populate the values.
# Secrets are available in the DataForGood Vaultwarden password manager
# under the collection: Quotaclimat - Désinformation/

# Credentials for the instance-level admin user (set at instance creation)
TF_VAR_postgres_admin_user=
TF_VAR_postgres_admin_password=

# Password for the barometre-dev-admin database user
TF_VAR_barometre_admin_password=

# Prod + dev credentials for the migration script (bin/migrate_barometre_dev.sh)
PROD_POSTGRES_HOST=
PROD_POSTGRES_USER=
PROD_POSTGRES_PASSWORD=
# PROD_POSTGRES_PORT=5432  # optional — defaults to 5432

DEV_POSTGRES_USER=      # same as TF_VAR_postgres_admin_user
DEV_POSTGRES_PASSWORD=  # same as TF_VAR_postgres_admin_password
