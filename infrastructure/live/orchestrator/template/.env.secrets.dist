# Existing Scaleway RDB instance name in the barometre project
TF_VAR_barometre_pg_instance_name=rdb-poc

# Password for the kestra PostgreSQL user created on the barometre RDB instance
TF_VAR_kestra_db_password=

# Kestra web UI admin credentials
TF_VAR_kestra_admin_email=admin@kestra.io
TF_VAR_kestra_admin_password=

# Space-separated project names Kestra gets access to (dev only — prod uses org-wide access)
# e.g. TF_VAR_policy_project_names='["rrs-dev","barometre-dev","advertising-dev","climate-safeguards-dev"]'
TF_VAR_policy_project_names='["rrs-dev","barometre-dev","advertising-dev","climate-safeguards-dev"]'

# Tag of the Kestra image mirrored into the Scaleway registry
TF_VAR_kestra_image_tag=v1.2
